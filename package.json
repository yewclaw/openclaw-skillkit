{
  "name": "skillforge",
  "version": "0.1.0",
  "description": "Author, validate, package, inspect, and review reusable skills with aligned CLI and Studio workflows.",
  "license": "MIT",
  "type": "commonjs",
  "bin": {
    "skillforge": "dist/cli.js"
  },
  "files": [
    "dist",
    "src",
    "examples",
    "LICENSE",
    "README.md",
    "tsconfig.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "node --test test/*.test.js",
    "benchmark": "node bench/index.js",
    "bench": "node bench/index.js",
    "verify": "node scripts/verify.js",
    "start": "node dist/cli.js",
    "dev": "node src/cli.ts",
    "ui": "node dist/cli.js serve"
  },
  "keywords": [
    "skillforge",
    "skills",
    "cli",
    "toolkit",
    "validation",
    "packaging"
  ],
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "typescript": "^5.8.2"
  }
}
